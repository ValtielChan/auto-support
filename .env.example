# ─── Auto Support configuration ──────────────────────────────────────────────
#
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the REQUIRED values below (or run ./setup.sh to do it for you).
#   3. Start:            docker compose up -d --build
#
#   The app is then available at  http://localhost:8000
#   Log in with ADMIN_USERNAME / ADMIN_PASSWORD.
#
# ─────────────────────────────────────────────────────────────────────────────


# ═══ REQUIRED ════════════════════════════════════════════════════════════════

# Signs login tokens AND encrypts stored credentials (mailbox passwords, API key).
# Generate a strong random value:   openssl rand -hex 32
# ⚠  Do NOT change this after first run - it would invalidate every stored password.
SECRET_KEY=

# The admin account, created automatically on first startup. This is your web login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=


# ═══ OPTIONAL - LLM provider ═════════════════════════════════════════════════
# You can leave these blank and configure them later in the web UI → Settings.

# OpenAI (or any OpenAI-compatible API) key.
OPENAI_API_KEY=

# Base URL for non-OpenAI, OpenAI-compatible endpoints (Ollama, Mistral,
# OpenRouter, Azure OpenAI…). Leave blank for the official OpenAI API.
OPENAI_BASE_URL=

# Default chat model used when a mailbox's agent doesn't override it.
DEFAULT_MODEL=gpt-5.6-terra


# ═══ OPTIONAL - hosting ══════════════════════════════════════════════════════

# Host port the app is exposed on (http://localhost:APP_PORT).
APP_PORT=8000


# ═══ OPTIONAL - database ═════════════════════════════════════════════════════
# The bundled PostgreSQL container uses these. Changing POSTGRES_PASSWORD is
# recommended for a production deployment.
POSTGRES_USER=autosupport
POSTGRES_PASSWORD=autosupport
POSTGRES_DB=autosupport

# To use your OWN PostgreSQL server instead of the bundled one, set DATABASE_URL
# and remove the `db` service from docker-compose.yml. Tables are created on start.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
